# Copy this file to .env for local development.
# For local dev you can leave DATABASE_URL and DATABASE_AUTH_TOKEN blank -
# the app will automatically use a local SQLite file at ./data/tickets.db

# ---- Production (Turso) ----
# Get these from: turso db show <your-db-name> --url
# and:            turso db tokens create <your-db-name>
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# ---- Auth ----
# Secret used to sign manager login sessions - set a long random string in production
JWT_SECRET=dev-only-secret-change-me

# ---- Default seeded IT manager account (first run only) ----
DEFAULT_MANAGER_USERNAME=admin
DEFAULT_MANAGER_PASSWORD=admin123

PORT=3000
